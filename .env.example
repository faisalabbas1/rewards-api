# Ethereum
ETH_RPC_URL=https://mainnet.infura.io/v3/your_key
ETH_CHAIN_ID=1
ETH_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Optional: override default Uniswap v3 addresses (mainnet defaults pre-filled)
ETH_UNISWAP_V3_ROUTER=0xE592427A0AEce92De3Edee1F18E0157C05861564
ETH_UNISWAP_V3_QUOTER=0x61fFE014bA17989E743c5F6cB21bF9697530B21e

# Optional default recipient address for swaps (if omitted, uses sender)
DEFAULT_RECIPIENT=0xYourRecipientAddress
